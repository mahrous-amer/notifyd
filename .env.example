# ─── Required ──────────────────────────────────────────────
# REQUIRED: PostgreSQL password (used to construct DATABASE_URL in docker-compose)
POSTGRES_PASSWORD=password

# REQUIRED: Full database connection string
DATABASE_URL=postgres://notifyd:password@localhost:5432/notifyd?sslmode=disable

# REQUIRED: JWT signing key -- MUST be a secure 256-bit key in production
JWT_SIGNING_KEY=your-256-bit-secret-key-here

# ─── Server ────────────────────────────────────────────────
API_PORT=8080
SHUTDOWN_TIMEOUT=15s
LOG_LEVEL=info

# ─── Database pool ─────────────────────────────────────────
DB_MAX_CONNS=25
DB_MIN_CONNS=5
DB_MAX_CONN_LIFETIME=30m
DB_MAX_CONN_IDLE_TIME=5m
DB_HEALTH_CHECK_PERIOD=30s

# ─── Redis ─────────────────────────────────────────────────
REDIS_ADDR=127.0.0.1:6379
# REQUIRED in production: Redis authentication password
REDIS_PASSWORD=
REDIS_DB=0

# ─── JWT ───────────────────────────────────────────────────
JWT_EXPIRATION=1h
JWT_ISSUER=notifyd

# ─── Worker ────────────────────────────────────────────────
WORKER_CONCURRENCY=10
MAX_RETRIES=5
MIN_RETRY_DELAY=15s
MAX_RETRY_DELAY=30m

# ─── Admin Bot (optional) ──────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT=0

# ─── Admin API (optional) ──────────────────────────────────
ADMIN_API_KEY=
ADMIN_API_SECRET=

# ─── Docker / CI (optional) ────────────────────────────────
# IMAGE_TAG=latest
# DOCKER_REGISTRY=ghcr.io/bse
# GIT_COMMIT=
